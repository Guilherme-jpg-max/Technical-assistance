{
  "paths": {
    "/api/entrada-aparelhos": {
      "get": {
        "summary": "Lista todos os aparelhos",
        "tags": ["Itens"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista retornada com sucesso" },
          "401": { "description": "Não autorizado" }
        }
      },
      "post": {
        "summary": "Cria um novo aparelho",
        "tags": ["Itens"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "codigo": { "type": "string", "example": "AP001" },
                  "descricao": { "type": "string", "example": "Notebook Dell" },
                  "cliente": { "type": "string", "example": "João Silva" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Aparelho criado com sucesso" },
          "400": { "description": "Dados inválidos" }
        }
      }
    },
    "/api/entrada-aparelhos/{id}": {
      "get": {
        "summary": "Busca um aparelho pelo ID",
        "tags": ["Itens"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID do aparelho"
          }
        ],
        "responses": {
          "200": { "description": "Aparelho encontrado" },
          "404": { "description": "Aparelho não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um aparelho pelo ID",
        "tags": ["Itens"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID do aparelho"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "descricao": { "type": "string", "example": "Notebook Dell Atualizado" },
                  "cliente": { "type": "string", "example": "João Silva" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Aparelho atualizado com sucesso" },
          "404": { "description": "Aparelho não encontrado" }
        }
      },
      "delete": {
        "summary": "Remove um aparelho pelo ID",
        "tags": ["Itens"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID do aparelho"
          }
        ],
        "responses": {
          "200": { "description": "Aparelho removido com sucesso" },
          "404": { "description": "Aparelho não encontrado" }
        }
      }
    },
    "/api/entrada-aparelhos/search/{codigo}": {
      "get": {
        "summary": "Busca aparelho pelo código",
        "tags": ["Itens"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "codigo",
            "required": true,
            "schema": { "type": "string" },
            "description": "Código do aparelho"
          }
        ],
        "responses": {
          "200": { "description": "Aparelho encontrado" },
          "404": { "description": "Aparelho não encontrado" }
        }
      }
    },
    "/api/entrada-aparelhos/pdf/download": {
      "get": {
        "summary": "Gera e baixa o PDF dos aparelhos",
        "tags": ["Itens"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "PDF gerado com sucesso",
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          }
        }
      }
    },
    "/api/orcamentos": {
      "get": {
        "summary": "Lista todos os orçamentos",
        "tags": ["Orçamentos"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Lista retornada com sucesso" },
          "401": { "description": "Não autorizado" }
        }
      },
      "post": {
        "summary": "Cria um novo orçamento",
        "tags": ["Orçamentos"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "aparelhoId": { "type": "string", "example": "AP001" },
                  "valor": { "type": "number", "example": 350.00 },
                  "descricao": { "type": "string", "example": "Troca de tela" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Orçamento criado com sucesso" },
          "400": { "description": "Dados inválidos" }
        }
      }
    },
    "/api/orcamentos/{id}": {
      "get": {
        "summary": "Busca um orçamento pelo ID",
        "tags": ["Orçamentos"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID do orçamento"
          }
        ],
        "responses": {
          "200": { "description": "Orçamento encontrado" },
          "404": { "description": "Orçamento não encontrado" }
        }
      },
      "put": {
        "summary": "Atualiza um orçamento pelo ID",
        "tags": ["Orçamentos"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID do orçamento"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "valor": { "type": "number", "example": 400.00 },
                  "descricao": { "type": "string", "example": "Troca de tela e bateria" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Orçamento atualizado com sucesso" },
          "404": { "description": "Orçamento não encontrado" }
        }
      },
      "delete": {
        "summary": "Remove um orçamento pelo ID",
        "tags": ["Orçamentos"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "string" },
            "description": "ID do orçamento"
          }
        ],
        "responses": {
          "200": { "description": "Orçamento removido com sucesso" },
          "404": { "description": "Orçamento não encontrado" }
        }
      }
    },
    "/api/auth/logar": {
      "post": {
        "summary": "Realiza o login do usuário",
        "tags": ["Autenticação"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "admin@email.com" },
                  "senha": { "type": "string", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login realizado com sucesso" },
          "401": { "description": "Credenciais inválidas" }
        }
      }
    },
    "/api/auth/verificar-2fa": {
  "post": {
    "summary": "Verifica o código 2FA e retorna o token",
    "tags": ["Autenticação"],
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "email": { "type": "string", "example": "admin@email.com" },
              "codigo": { "type": "string", "example": "123456" }
            }
          }
        }
      }
    },
    "responses": {
      "200": { "description": "Token retornado com sucesso" },
      "401": { "description": "Código inválido ou expirado" }
    }
  }
}
  }
}